{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "ignoreDeprecations": "6.0",
    "types": ["node"]
  },
  "include": ["src/**/*", "runtime/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "test",
    "templates",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/__tests__/**",
    "src/schema/generate-json-schema.ts",
    "runtime/**/*.test.ts",
    "runtime/**/*.spec.ts",
    "runtime/**/__tests__/**"
  ]
}
