# If codegen generates into packages/, use a more specific ignore

# Runtime artifacts
agent-logs/
codegen.config.yaml

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Dev companion
.dev-app.pid
.dev-app.log

# Environment
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*

# Unit-test tmp dirs (emit-typecheck fixtures, etc.)
test/tmp/
