# Dependencies
node_modules/

# Lockfiles (regenerated on install)
bun.lock
package-lock.json
yarn.lock
pnpm-lock.yaml

# Build output
dist/
build/
*.tsbuildinfo

# Test output (regenerated)
test/gen/

# Codegen output (generated from entity YAML — never commit)
gen/
app/
apps/
modules/

# Codegen output packages (not our source packages)
