# Dependencies
node_modules/

# Lockfiles (regenerated on install)
bun.lock
package-lock.json
yarn.lock
pnpm-lock.yaml

# Build output
dist/
build/
*.tsbuildinfo

# Test output (regenerated)
test/gen/

# Codegen output (generated from entity YAML — never commit)
gen/
app/
apps/
modules/

# Codegen output packages (not our source packages).
# packages/graph-components/ is real source; everything else under
# packages/ is generated by `bun test/run-test.ts generate` from the
# fixtures in test/fixtures/ and must not be committed.
packages/api/
packages/db/
# `runtime/subsystems/jobs/generated/` is a per-run codegen artifact
# too (schema.single-tenant.ts + schema.multi-tenant.ts variants).
# The other files under `runtime/subsystems/*/generated/` (e.g.
# `events/generated/bus.ts`) ARE committed — they ship in the runtime
# module that consumers consume.
runtime/subsystems/jobs/generated/

# Runtime artifacts
agent-logs/
codegen.config.yaml

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Dev companion
.dev-app.pid
.dev-app.log

# Environment
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*

# Unit-test tmp dirs (emit-typecheck fixtures, etc.)
test/tmp/
