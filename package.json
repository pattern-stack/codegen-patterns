{
  "name": "@pattern-stack/codegen",
  "version": "0.2.0",
  "description": "Entity-driven code generation for full-stack TypeScript applications",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "codegen": "./src/cli/index.ts"
  },
  "scripts": {
    "codegen": "bun src/cli/index.ts",
    "test": "bun test/run-test.ts full",
    "test:integration": "bun test/scaffold/run-integration.ts",
    "test:integration:quick": "bun test/scaffold/run-integration.ts --skip-codegen"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "@cubejs-client/core": "^1.6.33",
    "chalk": "^5.6.2",
    "clipanion": "^4.0.0-rc.4",
    "drizzle-orm": "^0.45.2",
    "ora": "^9.3.0",
    "yaml": "^2.8.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@nestjs/common": "10",
    "@nestjs/core": "10",
    "@types/bun": "latest",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "peerDependencies": {
    "hygen": "^6.2.11",
    "ioredis": ">=5"
  },
  "peerDependenciesMeta": {
    "ioredis": {
      "optional": true
    }
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "keywords": [
    "codegen",
    "code-generation",
    "typescript",
    "nestjs",
    "drizzle",
    "entity",
    "yaml"
  ],
  "license": "MIT"
}
