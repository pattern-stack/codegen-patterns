---
to: <%= outputPaths.syncSourceModule %>
skip_if: <%= !hasDetection || !isCleanArchitecture %>
force: true
---
/**
 * <%= className %>SyncSourceModule
 *
 * Generated by entity codegen (#226-7) from the entity YAML's
 * `detection:` block. Do not edit directly — regenerate by editing
 * the YAML and re-running `codegen entity new`.
 *
 * What this module wires:
 *   - `<%= syncAdapterToken %>` (consumer-supplied) — the
 *     `PollFetchCallback<<%= className %>>` the primitive invokes per run.
 *     Bind this token in your feature module:
 *       { provide: <%= syncAdapterToken %>, useValue: myAdapter }
 *
 *   - `<%= syncLoopbackToken %>` (optional, consumer-supplied) — when an
 *     `ILoopbackFingerprintStore<<%= className %>>` is bound, the factory
 *     composes `createLoopbackMiddleware(store)` into the primitive's
 *     middleware chain. Loopback suppression is opt-in per entity (#226-5,
 *     ADR-033) — the orchestrator no longer accepts a fingerprint store.
 *
 *   - `SYNC_CHANGE_SOURCE` — bound by the factory below to a
 *     `new PollChangeSource({ adapter, config: detectionConfig, middlewares })`.
 *     The detection literal is inlined from YAML; no runtime Zod parse —
 *     the codegen pipeline already validated against `DetectionConfigSchema`.
 *
 * The module is NOT `global: true`. Import it from your per-entity feature
 * module alongside `ExecuteSyncUseCase` and your `ISyncSink` binding:
 *
 * ```ts
 * @Module({
 *   imports: [<%= syncSourceModuleClass %>],
 *   providers: [
 *     { provide: <%= syncAdapterToken %>, useValue: myAdapter },
 *     // optional: { provide: <%= syncLoopbackToken %>, useClass: MyLoopbackStore },
 *     { provide: SYNC_SINK, useClass: <%= className %>SyncSink },
 *     ExecuteSyncUseCase,
 *   ],
 * })
 * export class <%= className %>SyncFeatureModule {}
 * ```
 */

import { Module, type Provider } from '@nestjs/common';
import {
  createLoopbackMiddleware,
  PollChangeSource,
  SYNC_CHANGE_SOURCE,
  type ChangeMiddleware,
  type DetectionConfig,
  type ILoopbackFingerprintStore,
  type PollFetchCallback,
} from '@shared/subsystems/sync';
import { <%= className %> } from '<%= syncSourceToEntityImport %>';

/**
 * Per-entity adapter-callback token. The consumer feature module provides
 * the `PollFetchCallback<<%= className %>>` value at this token; this
 * module declares the symbol and consumes it in the factory.
 */
export const <%= syncAdapterToken %> = '<%= syncAdapterToken %>' as const;

/**
 * Optional loopback fingerprint-store token. When bound, the factory
 * composes `createLoopbackMiddleware(store)` as the outermost middleware.
 */
export const <%= syncLoopbackToken %> = '<%= syncLoopbackToken %>' as const;

/**
 * Detection config inlined from the entity YAML. Validated at codegen
 * time by `DetectionConfigSchema`; passed by-value to the primitive at
 * construction. Edit the YAML, not this constant.
 */
const detectionConfig: DetectionConfig = <%- detectionConfigJson %>;

const syncSourceProvider: Provider = {
  provide: SYNC_CHANGE_SOURCE,
  useFactory: (
    adapter: PollFetchCallback<<%= className %>>,
    loopbackStore: ILoopbackFingerprintStore<<%= className %>> | null,
  ) => {
    const middlewares: ChangeMiddleware<<%= className %>>[] = loopbackStore
      ? [createLoopbackMiddleware<<%= className %>>(loopbackStore)]
      : [];
    return new PollChangeSource<<%= className %>>({
      adapter,
      config: detectionConfig,
      middlewares,
    });
  },
  inject: [
    <%= syncAdapterToken %>,
    { token: <%= syncLoopbackToken %>, optional: true },
  ],
};

@Module({
  providers: [syncSourceProvider],
  exports: [SYNC_CHANGE_SOURCE],
})
export class <%= syncSourceModuleClass %> {}
