{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@gen/*": ["../../*"],
      "@shared/*": ["./shared/*", "../../shared/*"]
    }
  },
  "include": [
    "src/**/*",
    "shared/**/*",
    "schema.ts",
    "drizzle.config.ts",
    "../../modules/**/*"
  ]
}
