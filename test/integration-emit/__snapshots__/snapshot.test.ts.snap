@Injectable()
export class MeetingSink implements IIntegrationSink<MeetingCanonical> {
  constructor(
    private readonly repo: MeetingRepository,
    private readonly provider: string,
  ) {}

  async findByExternalId(userId: string, externalId: string): Promise<MeetingCanonical | null> {
    const row = await this.repo.findByExternalIdProjected(externalId, this.provider);
    // The repo lookup is (provider, externalId)-scoped. If your external_id is not
    // globally unique, enforce ownership here (e.g. row.userId === userId).
