{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": "..",
    // Generated/runtime code uses node globals (process.env, crypto.randomUUID).
    // Declared explicitly so the typecheck does not depend on @types/node being
    // pulled in transitively by an optional-peer import (e.g. ioredis). Real
    // consumer projects always have @types/node.
    "types": ["node"],
    "paths": {
      "@shared/subsystems/*": ["runtime/subsystems/*"],
      "@shared/constants/*": ["runtime/constants/*"],
      "@shared/types/*": ["runtime/types/*"],
      "@shared/openapi": ["runtime/shared/openapi/index.ts"],
      "@shared/openapi/*": ["runtime/shared/openapi/*"],
      "@shared/*": ["runtime/shared/*", "test/scaffold/shared/*"]
    }
  },
  "include": [
    "../packages/api/src/domain/**/*"
  ]
}
